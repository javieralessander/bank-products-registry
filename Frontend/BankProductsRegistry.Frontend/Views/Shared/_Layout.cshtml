<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BankRED - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --bg-main: #0f111a; /* Fondo principal muy oscuro */
            --bg-sidebar: #151928; /* Fondo de la barra lateral */
            --border-color: #2d3348; /* Color de las líneas divisorias */
            --text-main: #ffffff;
            --text-muted: #8b94a5;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow-x: hidden;
        }

        .sidebar {
            background-color: var(--bg-sidebar);
            min-height: 100vh;
            padding: 20px 0;
            border-right: 1px solid var(--border-color);
            position: fixed;
            width: inherit;
            z-index: 1000;
        }

        .main-content {
            margin-left: 16.666667%;
            min-height: 100vh;
            padding: 30px;
        }

        .nav-link {
            color: var(--text-muted);
            padding: 12px 24px;
            margin-bottom: 5px;
            border-radius: 0 20px 20px 0;
            margin-right: 20px;
            transition: 0.3s;
            font-size: 0.95rem;
            text-decoration: none;
        }

            .nav-link:hover, .nav-link.active {
                background-color: #242b3d;
                color: var(--text-main);
            }

        .brand-logo {
            color: var(--text-main);
            font-weight: bold;
            font-size: 1.2rem;
            padding: 0 24px 30px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .brand-dot {
            width: 12px;
            height: 12px;
            background-color: #3b82f6;
            border-radius: 50%;
            display: inline-block;
        }

        .user-profile {
            position: absolute;
            bottom: 20px;
            padding: 0 24px;
            display: flex;
            align-items: center;
            gap: 15px;
            width: 100%;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            background-color: #3b82f6;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            flex-shrink: 0;
        }
    </style>
</head>
<body>
    <div class="container-fluid p-0">
        <div class="row g-0">
            <div class="col-2 sidebar">
                <a href="#" class="brand-logo"><span class="brand-dot"></span> BankRED</a>
                <ul class="nav flex-column mb-auto">
                    <li class="nav-item w-100"><a href="#" class="nav-link active">Dashboard</a></li>
                    <li class="nav-item w-100"><a href="#" class="nav-link">Clientes</a></li>
                    <li class="nav-item w-100"><a href="#" class="nav-link">Prod. Financieros</a></li>
                    <li class="nav-item w-100"><a href="#" class="nav-link">Prod. Contratados</a></li>
                    <li class="nav-item w-100"><a href="#" class="nav-link">Transacciones</a></li>
                    <li class="nav-item w-100"><a href="#" class="nav-link">Empleados</a></li>
                </ul>
                <div class="user-profile">
                    <div class="user-avatar">JM</div>
                    <div>
                        <div class="text-white" style="font-size: 0.9rem; line-height: 1;">Javier Montero</div>
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">Admin</div>
                    </div>
                </div>
            </div>
            <div class="col-10 main-content">
                @RenderBody()
            </div>
        </div>
    </div>
</body>
</html>