@model IEnumerable<BankProductsRegistry.Frontend.Models.UserManagementViewModel>
@{
    ViewData["Title"] = "Usuarios";
}

<style>
    .page-header { margin-bottom: 24px; }
    .page-title { font-size: 1.5rem; font-weight: 600; margin-bottom: 4px; color: white; }
    .page-subtitle { color: var(--text-muted); font-size: 0.9rem; }
    .toolbar { display: flex; justify-content: space-between; gap: 16px; margin-bottom: 24px; }
    .btn-primary-custom {
        background-color: #3b82f6; border: none; padding: 10px 20px; font-weight: 600;
        border-radius: 8px; color: white; transition: 0.3s;
    }
    .btn-primary-custom:hover { background-color: #2563eb; transform: translateY(-1px); color: white; }
    .table-container { background-color: #1a1d2d; border-radius: 12px; border: 1px solid var(--border-color); overflow: hidden; }
    .custom-table { width: 100%; color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0; border-collapse: collapse; }
    .custom-table th { padding: 14px 16px; font-weight: 500; color: #8b94a5; border-bottom: 1px solid var(--border-color); text-align: left; }
    .custom-table td { padding: 14px 16px; vertical-align: middle; border-bottom: 1px solid var(--border-color); color: #d1d5db; }
    .custom-table tbody tr:hover { background-color: #1f2335; }
    .badge-active { background-color: rgba(16,185,129,0.1); color: #10b981; padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; border: 1px solid rgba(16,185,129,0.2); }
    .badge-inactive { background-color: rgba(239,68,68,0.1); color: #ef4444; padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; border: 1px solid rgba(239,68,68,0.2); }
    .badge-role { padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; border: 1px solid transparent; }
    .badge-role-admin { background-color: rgba(245, 158, 11, 0.12); color: #f59e0b; border-color: rgba(245, 158, 11, 0.25); }
    .badge-role-operator { background-color: rgba(59, 130, 246, 0.12); color: #60a5fa; border-color: rgba(59, 130, 246, 0.25); }
    .badge-role-readonly { background-color: rgba(139, 148, 165, 0.14); color: #cbd5e1; border-color: rgba(139, 148, 165, 0.3); }
    .inline-form { display: flex; gap: 8px; align-items: center; }
    .input-small, .select-small {
        background: #0f111a; color: #d1d5db; border: 1px solid #2d3348;
        border-radius: 8px; padding: 6px 8px; font-size: 0.82rem;
    }
    .btn-mini {
        background: #27324a; color: #e5e7eb; border: 1px solid #36425e;
        border-radius: 8px; padding: 6px 10px; font-size: 0.8rem;
    }
    .btn-mini:hover { background: #3b82f6; border-color: #3b82f6; color: white; }
</style>

<div class="page-header">
    <h1 class="page-title">Usuarios del Sistema</h1>
    <div class="page-subtitle">Administración de accesos, roles y credenciales</div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" style="background-color: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2); font-size: 0.9rem; padding: 12px; border-radius: 8px; margin-bottom: 16px;">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" style="background-color: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); font-size: 0.9rem; padding: 12px; border-radius: 8px; margin-bottom: 16px;">
        @TempData["ErrorMessage"]
    </div>
}

<div class="toolbar">
    <div></div>
    <a href="@Url.Action("Create", "Users")" class="btn-primary-custom text-decoration-none">+ Nuevo Usuario</a>
</div>

<div class="table-container">
    <table class="custom-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Usuario</th>
                <th>Nombre completo</th>
                <th>Email</th>
                <th>Rol actual</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (ViewBag.ErrorMessage != null)
            {
                <tr><td colspan="7" class="text-center text-danger" style="padding: 18px;">@ViewBag.ErrorMessage</td></tr>
            }
            else if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center" style="padding: 18px; color: #8b94a5;">No hay usuarios registrados.</td></tr>
            }
            else
            {
                foreach (var user in Model)
                {
                    var currentRole = user.Roles.FirstOrDefault() ?? "Consulta";
                    var roleClass = currentRole == "Admin"
                        ? "badge-role-admin"
                        : currentRole == "Operador"
                            ? "badge-role-operator"
                            : "badge-role-readonly";
                    var activeSelected = user.IsActive ? "selected" : null;
                    var inactiveSelected = user.IsActive ? null : "selected";
                    var adminSelected = currentRole == "Admin" ? "selected" : null;
                    var operatorSelected = currentRole == "Operador" ? "selected" : null;
                    var readonlySelected = currentRole == "Consulta" ? "selected" : null;
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.UserName</td>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td><span class="badge-role @roleClass">@currentRole</span></td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge-active">Activo</span>
                            }
                            else
                            {
                                <span class="badge-inactive">Inactivo</span>
                            }
                        </td>
                        <td>
                            <div style="display: grid; gap: 8px;">
                                <form asp-action="UpdateStatus" method="post" class="inline-form">
                                    <input type="hidden" name="Id" value="@user.Id" />
                                    <select name="IsActive" class="select-small">
                                        <option value="true" selected="@activeSelected">Activo</option>
                                        <option value="false" selected="@inactiveSelected">Inactivo</option>
                                    </select>
                                    <button type="submit" class="btn-mini">Estado</button>
                                </form>

                                <form asp-action="UpdateRole" method="post" class="inline-form">
                                    <input type="hidden" name="Id" value="@user.Id" />
                                    <select name="Role" class="select-small">
                                        <option value="Admin" selected="@adminSelected">Admin</option>
                                        <option value="Operador" selected="@operatorSelected">Operador</option>
                                        <option value="Consulta" selected="@readonlySelected">Consulta</option>
                                    </select>
                                    <button type="submit" class="btn-mini">Rol</button>
                                </form>

                                <form asp-action="ResetPassword" method="post" class="inline-form" onsubmit="return confirm('¿Restablecer contraseña para @user.UserName?');">
                                    <input type="hidden" name="Id" value="@user.Id" />
                                    <input type="password" name="NewPassword" class="input-small" minlength="8" placeholder="Nueva contraseña" required />
                                    <button type="submit" class="btn-mini">Reset</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
