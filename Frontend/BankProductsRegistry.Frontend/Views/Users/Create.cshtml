@model BankProductsRegistry.Frontend.Models.UserCreateViewModel
@{
    ViewData["Title"] = "Nuevo Usuario";
    var clients = ViewBag.ClientOptions as List<BankProductsRegistry.Frontend.Models.ClientViewModel> ?? new List<BankProductsRegistry.Frontend.Models.ClientViewModel>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .page-header { margin-bottom: 24px; }
    .page-title { font-size: 1.5rem; font-weight: 600; margin-bottom: 4px; color: white; }
    .page-subtitle { color: var(--text-muted); font-size: 0.9rem; }
    .form-card {
        background-color: #151928; border: 1px solid #2d3348; border-radius: 14px;
        padding: 30px; max-width: 760px;
    }
    .form-label-custom {
        color: #8b94a5; font-size: 0.8rem; font-weight: 600;
        margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px;
    }
    .input {
        background-color: #0f111a; border: 1px solid #2d3348; color: white;
        border-radius: 10px; padding: 10px 12px;
    }
    .input:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.18); }
    .btn-primary-custom {
        background-color: #3b82f6; border: none; padding: 10px 18px; border-radius: 8px; color: #fff; font-weight: 600;
    }
    .btn-primary-custom:hover { background-color: #2563eb; color: #fff; }
    .btn-secondary-custom {
        background: transparent; color: #8b94a5; border: 1px solid #2d3348; padding: 10px 18px; border-radius: 8px; text-decoration: none;
    }
    .btn-secondary-custom:hover { color: white; background: #2d3348; }
    .validation-error { color: #ef4444; font-size: 0.78rem; margin-top: 4px; display: block; }
    .hint-text { color: #8b94a5; font-size: 0.78rem; margin-top: 4px; }
</style>

<div class="page-header">
    <h1 class="page-title">Crear Usuario</h1>
    <div class="page-subtitle">Alta de usuario para acceso al sistema</div>
</div>

<div class="form-card">
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger" style="background-color: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2);">
            @ViewBag.ErrorMessage
        </div>
    }

    <form asp-action="Create" method="post">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label-custom">Usuario</label>
                <input asp-for="UserName" class="input w-100" placeholder="usuario" required />
                <span asp-validation-for="UserName" class="validation-error"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label-custom">Email</label>
                <input asp-for="Email" type="email" class="input w-100" placeholder="usuario@bank.local" required />
                <span asp-validation-for="Email" class="validation-error"></span>
            </div>
            <div class="col-md-8">
                <label class="form-label-custom">Nombre completo</label>
                <input asp-for="FullName" class="input w-100" placeholder="Nombre Apellido" required />
                <span asp-validation-for="FullName" class="validation-error"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label-custom">Rol</label>
                <select asp-for="Role" class="input w-100">
                    <option value="Admin">Admin</option>
                    <option value="Operador">Operador</option>
                    <option value="Consulta">Consulta</option>
                    <option value="Cliente">Cliente</option>
                </select>
                <span asp-validation-for="Role" class="validation-error"></span>
            </div>
            <div class="col-md-12" id="client-selector-row" style="display:none;">
                <label class="form-label-custom">Cliente asociado (solo rol Cliente)</label>
                <select asp-for="ClientId" class="input w-100">
                    <option value="">Seleccionar cliente</option>
                    @foreach (var client in clients.OrderBy(c => c.LastName).ThenBy(c => c.FirstName))
                    {
                        <option value="@client.Id">@client.FirstName @client.LastName - @client.NationalId</option>
                    }
                </select>
                <span asp-validation-for="ClientId" class="validation-error"></span>
            </div>
            <div class="col-md-8">
                <label class="form-label-custom">Contraseña inicial</label>
                <input asp-for="Password" type="password" minlength="8" class="input w-100" placeholder="Mínimo 8 caracteres" required />
                <span asp-validation-for="Password" class="validation-error"></span>
                <div class="hint-text">La contraseña debe tener mínimo 8 caracteres.</div>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <div class="form-check form-switch">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveSwitch" />
                    <label class="form-check-label text-light" for="isActiveSwitch">Activo</label>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end mt-4">
            <a asp-action="Index" class="btn-secondary-custom">Cancelar</a>
            <button type="submit" class="btn-primary-custom">Guardar Usuario</button>
        </div>
    </form>
</div>

<partial name="_ValidationScriptsPartial" />

<script>
    (function () {
        const roleSelect = document.getElementById("Role");
        const row = document.getElementById("client-selector-row");
        const clientSelect = document.getElementById("ClientId");

        function toggleClientSelector() {
            const isClientRole = roleSelect && roleSelect.value === "Cliente";
            row.style.display = isClientRole ? "block" : "none";
            if (!isClientRole && clientSelect) {
                clientSelect.value = "";
            }
        }

        if (roleSelect) {
            roleSelect.addEventListener("change", toggleClientSelector);
        }

        toggleClientSelector();
    })();
</script>
