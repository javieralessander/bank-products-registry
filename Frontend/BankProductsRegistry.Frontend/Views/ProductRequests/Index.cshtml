@model BankProductsRegistry.Frontend.Models.ProductRequestFormViewModel
@using BankProductsRegistry.Frontend.Models
@{
    ViewData["Title"] = "Solicitar producto";
    var financialProducts = ViewBag.FinancialProducts as List<FinancialProductPickItem> ?? new List<FinancialProductPickItem>();
}

<style>
    .form-card {
        background-color: #151928;
        border-radius: 16px;
        border: 1px solid #2d3348;
        padding: 32px;
        max-width: 560px;
    }
    .form-label-custom { color: #8b94a5; font-size: 0.8rem; font-weight: 600; margin-bottom: 8px; text-transform: uppercase; }
    .form-control-custom {
        background-color: #0f111a;
        border: 1px solid #2d3348;
        color: white;
        border-radius: 10px;
        padding: 12px 14px;
    }
    .btn-submit {
        background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%);
        border: none;
        padding: 12px 24px;
        font-weight: 600;
        border-radius: 10px;
        color: white;
    }
    .alert-custom {
        background-color: rgba(239, 68, 68, 0.08);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.15);
        border-radius: 10px;
        padding: 14px;
        margin-bottom: 20px;
    }
</style>

<div class="mb-4">
    <h1 class="text-white fw-bold" style="font-size: 1.5rem;">Solicitar nuevo producto</h1>
    <p class="text-muted mb-0">Elige un producto financiero disponible. Tu solicitud quedará <strong>pendiente</strong> hasta que un ejecutivo la apruebe.</p>
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert-custom"><i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.ErrorMessage</div>
}

<div class="form-card">
    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-4">
            <label class="form-label-custom" asp-for="FinancialProductId">Producto</label>
            <select asp-for="FinancialProductId" class="form-control form-control-custom w-100" required>
                <option value="">— Selecciona —</option>
                @foreach (var p in financialProducts)
                {
                    <option value="@p.Id">@p.ProductName</option>
                }
            </select>
            <span asp-validation-for="FinancialProductId" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label class="form-label-custom" asp-for="Amount">Monto solicitado (DOP)</label>
            <input asp-for="Amount" class="form-control form-control-custom w-100" type="number" step="0.01" min="0" />
            <span asp-validation-for="Amount" class="text-danger small"></span>
        </div>
        <button type="submit" class="btn-submit"><i class="bi bi-send me-2"></i>Enviar solicitud</button>
    </form>
</div>
