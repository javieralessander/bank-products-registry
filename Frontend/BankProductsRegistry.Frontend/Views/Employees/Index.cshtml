@model IEnumerable<BankProductsRegistry.Frontend.Models.EmployeeViewModel>
@{
    ViewData["Title"] = "Empleados";
}

<style>
    .page-header { margin-bottom: 24px; }
    .page-title { font-size: 1.5rem; font-weight: 600; margin-bottom: 4px; color: white; }
    .page-subtitle { color: var(--text-muted); font-size: 0.9rem; }
    .toolbar { display: flex; gap: 16px; margin-bottom: 24px; }
    .search-input {
        background-color: #1a1d2d; border: 1px solid var(--border-color); color: white;
        border-radius: 8px; padding: 10px 16px; flex-grow: 1; font-size: 0.9rem; transition: 0.3s;
    }
    .search-input:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 2px rgba(59,130,246,0.2); }
    .search-input::placeholder { color: #6b7280; }
    .btn-primary-custom {
        background-color: #3b82f6; border: none; padding: 10px 20px; font-weight: 600;
        border-radius: 8px; color: white; transition: 0.3s;
    }
    .btn-primary-custom:hover { background-color: #2563eb; transform: translateY(-1px); color: white; }
    .table-container {
        background-color: #1a1d2d; border-radius: 12px; border: 1px solid var(--border-color); overflow: hidden;
    }
    .custom-table { width: 100%; color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0; border-collapse: collapse; }
    .custom-table th {
        padding: 16px 20px; font-weight: 500; color: #8b94a5; border-bottom: 1px solid var(--border-color); text-align: left;
    }
    .custom-table td {
        padding: 16px 20px; vertical-align: middle; border-bottom: 1px solid var(--border-color); color: #d1d5db;
    }
    .custom-table tbody tr:hover { background-color: #1f2335; }
    .custom-table tbody tr:last-child td { border-bottom: none; }
    .employee-name-cell { display: flex; align-items: center; gap: 12px; color: white; font-weight: 500; }
    .employee-avatar {
        width: 32px; height: 32px; background-color: #3b82f6; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; color: white; font-size: 0.85rem; font-weight: bold;
    }
    .badge-active {
        background-color: rgba(16,185,129,0.1); color: #10b981; padding: 4px 10px; border-radius: 6px;
        font-size: 0.75rem; font-weight: 600; border: 1px solid rgba(16,185,129,0.2);
    }
    .badge-inactive {
        background-color: rgba(239,68,68,0.1); color: #ef4444; padding: 4px 10px; border-radius: 6px;
        font-size: 0.75rem; font-weight: 600; border: 1px solid rgba(239,68,68,0.2);
    }
    .action-icon { color: #6b7280; cursor: pointer; transition: 0.3s; margin-right: 12px; }
    .action-icon:hover { color: white; }
    .action-icon:last-child { margin-right: 0; }
</style>

<div class="page-header">
    <h1 class="page-title">Empleados</h1>
    <div class="page-subtitle">Gestión de empleados de la institución financiera</div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); font-size: 0.9rem; padding: 12px; border-radius: 8px; margin-bottom: 20px;">
        @TempData["ErrorMessage"]
    </div>
}

<div class="toolbar">
    <input type="text" id="searchInput" class="search-input" placeholder="Buscar por nombre, código, correo o departamento..." />
    <a href="@Url.Action("Create", "Employees")" class="btn-primary-custom text-decoration-none">+ Nuevo Empleado</a>
</div>

<div class="table-container">
    <table class="custom-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Código</th>
                <th>Email</th>
                <th>Departamento</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody id="employeesTableBody">
            @if (ViewBag.ErrorMessage != null)
            {
                <tr>
                    <td colspan="7" class="text-center text-danger" style="padding: 20px;">@ViewBag.ErrorMessage</td>
                </tr>
            }
            else if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center" style="padding: 30px; color: #8b94a5;">No hay empleados registrados en la base de datos.</td>
                </tr>
            }
            else
            {
                foreach (var employee in Model)
                {
                    var fullName = $"{employee.FirstName} {employee.LastName}";
                    var initial = string.IsNullOrWhiteSpace(employee.FirstName) ? "E" : employee.FirstName.Substring(0, 1).ToUpper();
                    <tr>
                        <td>@employee.Id</td>
                        <td>
                            <div class="employee-name-cell">
                                <div class="employee-avatar">@initial</div>
                                @fullName
                            </div>
                        </td>
                        <td>@employee.EmployeeCode</td>
                        <td>@employee.Email</td>
                        <td>@employee.Department</td>
                        <td>
                            @if (employee.IsActive)
                            {
                                <span class="badge-active">Activo</span>
                            }
                            else
                            {
                                <span class="badge-inactive">Inactivo</span>
                            }
                        </td>
                        <td>
                            <a href="@Url.Action("Edit", "Employees", new { id = employee.Id })" class="action-icon text-decoration-none" title="Editar">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" />
                                </svg>
                            </a>
                            <form asp-action="Delete" asp-route-id="@employee.Id" method="post" class="d-inline" onsubmit="return confirm('¿Estás seguro de que deseas eliminar permanentemente a @fullName?');">
                                <button type="submit" class="action-icon" style="background: transparent; border: none; padding: 0;" title="Eliminar">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                                    </svg>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<script>
    document.getElementById('searchInput').addEventListener('keyup', function () {
        var searchValue = this.value.toLowerCase();
        var tableRows = document.querySelectorAll('#employeesTableBody tr');

        tableRows.forEach(function (row) {
            if (row.cells.length > 1) {
                var rowText = row.textContent.toLowerCase();
                row.style.display = rowText.includes(searchValue) ? '' : 'none';
            }
        });
    });
</script>
