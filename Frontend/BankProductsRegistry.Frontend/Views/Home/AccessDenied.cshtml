@{
    Layout = null;
    ViewData["Title"] = "Acceso no permitido";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BankRED</title>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: system-ui, "Segoe UI", sans-serif;
            background: #12141d;
            color: #e2e8f0;
            padding: 24px;
        }
        .box {
            max-width: 420px;
            text-align: center;
            padding: 2rem;
            background: #1c1f2a;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 14px;
        }
        h1 { font-size: 1.25rem; margin: 0 0 0.75rem; color: #fff; }
        p { margin: 0 0 1.25rem; color: #94a3b8; font-size: 0.95rem; line-height: 1.5; }
        a {
            color: #3b82f6;
            font-weight: 600;
            text-decoration: none;
        }
        a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="box">
        <h1>Acceso no permitido</h1>
        <p>No tienes permiso para ver esta sección. Si necesitas un producto, usa <strong>Solicitar producto</strong> en el menú.</p>
        <p><a href="@Url.Action("Index", "Home")">Volver al inicio</a></p>
    </div>
</body>
</html>
