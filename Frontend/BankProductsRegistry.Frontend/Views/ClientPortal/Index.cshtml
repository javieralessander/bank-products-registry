@{
    ViewData["Title"] = "Mi Portal";
}

<style>
    .welcome-text {
        font-size: 1.8rem;
        font-weight: 700;
        color: white;
        margin-bottom: 5px;
    }

    .date-text {
        color: #8b94a5;
        font-size: 0.95rem;
        margin-bottom: 30px;
    }

    /* Tarjeta de Balance Principal */
    .balance-card {
        background: linear-gradient(135deg, #1e3a8a 0%, #172554 100%);
        border-radius: 16px;
        padding: 30px;
        position: relative;
        overflow: hidden;
        border: 1px solid #2563eb;
        box-shadow: 0 10px 30px rgba(29, 78, 216, 0.2);
        margin-bottom: 30px;
    }

        .balance-card::after {
            content: '\F18E'; /* Icono de banco de bootstrap icons */
            font-family: "bootstrap-icons";
            position: absolute;
            right: -20px;
            bottom: -30px;
            font-size: 12rem;
            color: rgba(255,255,255,0.03);
        }

    .balance-label {
        color: #93c5fd;
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
    }

    .balance-amount {
        font-size: 3rem;
        font-weight: 800;
        color: white;
        line-height: 1;
        margin-bottom: 20px;
    }

    .balance-currency {
        font-size: 1.5rem;
        font-weight: 500;
        color: #93c5fd;
    }

    /* Acciones Rápidas */
    .quick-actions {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        margin-bottom: 40px;
    }

    .action-btn {
        background-color: #151928;
        border: 1px solid #2d3348;
        border-radius: 12px;
        padding: 20px 10px;
        text-align: center;
        color: white;
        text-decoration: none;
        transition: 0.3s;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }

        .action-btn:hover {
            background-color: #1e243b;
            border-color: #3b82f6;
            transform: translateY(-3px);
            color: white;
        }

    .action-icon {
        font-size: 1.8rem;
    }

    .action-text {
        font-size: 0.9rem;
        font-weight: 600;
    }

    /* Mis Productos */
    .section-heading {
        color: white;
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 20px;
        border-bottom: 1px solid #2d3348;
        padding-bottom: 10px;
    }

    .product-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .product-item {
        background-color: #151928;
        border: 1px solid #2d3348;
        border-radius: 12px;
        padding: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: 0.2s;
        cursor: pointer;
    }

        .product-item:hover {
            background-color: #1a1d2d;
            border-color: #4b5563;
        }

    .product-info h5 {
        color: white;
        font-size: 1.05rem;
        font-weight: 600;
        margin: 0 0 5px 0;
    }

    .product-info p {
        color: #8b94a5;
        font-size: 0.85rem;
        margin: 0;
        letter-spacing: 1px;
    }

    .product-balance {
        text-align: right;
    }

        .product-balance h4 {
            color: white;
            font-size: 1.2rem;
            font-weight: 700;
            margin: 0 0 5px 0;
        }

    .product-status {
        font-size: 0.75rem;
        padding: 4px 10px;
        border-radius: 6px;
        background: rgba(16,185,129,0.1);
        color: #10b981;
        font-weight: 600;
        text-transform: uppercase;
    }
</style>

<div>
    <h1 class="welcome-text">Bienvenido a tu Banca Digital</h1>
    <p class="date-text">@DateTime.Now.ToString("dd 'de' MMMM, yyyy")</p>

    <div class="balance-card">
        <div class="balance-label">Balance Consolidado</div>
        <div class="balance-amount"><span class="balance-currency">DOP</span> ***,***.00</div>
        <div style="color: #bfdbfe; font-size: 0.9rem;"><i class="bi bi-shield-check"></i> Tus fondos están protegidos</div>
    </div>

    <div class="section-heading">Operaciones Rápidas</div>
    <div class="quick-actions">
        <a href="@Url.Action("Index", "Transactions")" class="action-btn">
            <i class="bi bi-send-fill action-icon" style="color: #10b981;"></i>
            <span class="action-text">Transferir</span>
        </a>
        <a href="@Url.Action("Index", "TravelNotices")" class="action-btn">
            <i class="bi bi-airplane-fill action-icon" style="color: #3b82f6;"></i>
            <span class="action-text">Notificar Viaje</span>
        </a>
        <a href="@Url.Action("Index", "Blocks")" class="action-btn">
            <i class="bi bi-shield-lock-fill action-icon" style="color: #ef4444;"></i>
            <span class="action-text">Seguridad</span>
        </a>
        <a href="@Url.Action("Index", "Transactions")" class="action-btn">
            <i class="bi bi-receipt action-icon" style="color: #f59e0b;"></i>
            <span class="action-text">Movimientos</span>
        </a>
    </div>

    <div class="section-heading mt-4">Mis Productos Activos</div>
    <div class="product-list">
        <div class="product-item">
            <div class="d-flex gap-3 align-items-center">
                <div style="width: 48px; height: 48px; background: rgba(59,130,246,0.1); color: #3b82f6; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                    <i class="bi bi-credit-card-fill"></i>
                </div>
                <div class="product-info">
                    <h5>Cuenta Ahorro Plus</h5>
                    <p>0001002001</p>
                </div>
            </div>
            <div class="product-balance">
                <h4>DOP ***,***.00</h4>
                <span class="product-status">Activo</span>
            </div>
        </div>
    </div>
</div>