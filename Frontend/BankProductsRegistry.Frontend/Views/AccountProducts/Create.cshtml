@using System.Text.Json
@model BankProductsRegistry.Frontend.Models.AccountProductCreateViewModel
@{
    ViewData["Title"] = "Nuevo Producto Contratado";
}

<style>
    /* Fondo oscuro total para simular el modal */
    body:not(.layout-client) {
        background-color: #0b0f19 !important;
    }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(0, 0, 0, 0.7);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .custom-modal {
        background-color: #151928;
        border-radius: 16px;
        border: 1px solid #2d3348;
        width: 100%;
        max-width: 800px;
        padding: 30px 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }

    .modal-header-custom {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 25px;
        border-bottom: 1px solid #2d3348;
        padding-bottom: 15px;
    }

    .modal-title {
        font-size: 1.4rem;
        font-weight: 600;
        color: white;
        margin: 0;
    }

    .modal-subtitle {
        color: #8b94a5;
        font-size: 0.9rem;
        margin-top: 5px;
    }

    .close-btn {
        background: transparent;
        border: none;
        color: #6b7280;
        font-size: 1.2rem;
        cursor: pointer;
        transition: 0.2s;
    }

        .close-btn:hover {
            color: white;
        }

    .form-label-small {
        color: #3b82f6;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 8px;
        letter-spacing: 0.5px;
    }

    .form-control-dark {
        background-color: #0f111a;
        border: 1px solid #2d3348;
        color: white;
        padding: 12px 15px;
        border-radius: 8px;
        font-size: 0.95rem;
        width: 100%;
    }

        .form-control-dark:focus {
            border-color: #3b82f6;
            outline: none;
            box-shadow: 0 0 0 2px rgba(59,130,246,0.2);
        }

        .form-control-dark::placeholder {
            color: #4b5563;
        }

    /* Estilos para los Radio Buttons (Estado) */
    .status-group {
        display: flex;
        background-color: #0f111a;
        border-radius: 8px;
        border: 1px solid #2d3348;
        overflow: hidden;
    }

    .status-option {
        flex: 1;
        text-align: center;
    }

        .status-option input[type="radio"] {
            display: none;
        }

        .status-option label {
            display: block;
            padding: 12px;
            color: #8b94a5;
            cursor: pointer;
            font-weight: 500;
            font-size: 0.9rem;
            transition: 0.2s;
            margin: 0;
        }

        .status-option input[type="radio"]:checked + label {
            background-color: #3b82f6;
            color: white;
        }

    .info-box {
        background-color: rgba(59, 130, 246, 0.1);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 8px;
        padding: 12px 15px;
        color: #60a5fa;
        font-size: 0.85rem;
        margin-top: 15px;
    }

    .btn-create {
        background-color: #3b82f6;
        border: none;
        padding: 12px 25px;
        border-radius: 8px;
        color: white;
        font-weight: 600;
        transition: 0.2s;
    }

        .btn-create:hover {
            background-color: #2563eb;
        }

    .btn-cancel {
        background: transparent;
        border: none;
        color: #8b94a5;
        font-weight: 600;
        padding: 12px 25px;
        text-decoration: none;
        transition: 0.2s;
    }

        .btn-cancel:hover {
            color: white;
        }
</style>

<div class="modal-overlay">
    <div class="custom-modal">
        <div class="modal-header-custom">
            <div>
                <h2 class="modal-title">Nuevo Producto Contratado</h2>
                <div class="modal-subtitle">Vincula un cliente con un producto financiero</div>
            </div>
            <a href="@Url.Action("Index")" class="close-btn">&times;</a>
        </div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="info-box" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; border-color: rgba(239, 68, 68, 0.2);">
                @ViewBag.ErrorMessage
            </div>
        }

        <form asp-action="Create" method="post">

            <div class="mb-4">
                <div class="form-label-small">CLIENTE</div>
                <label style="color: #8b94a5; font-size: 0.85rem; margin-bottom: 5px;">Cliente *</label>
                <select asp-for="ClientId" class="form-control-dark" required>
                    <option value="" disabled selected>Selecciona un cliente...</option>
                    @if (ViewBag.Clients != null)
                    {
                        var clients = JsonDocument.Parse(ViewBag.Clients.ToString()).RootElement.EnumerateArray();
                        foreach (var c in clients)
                        {
                            <option value="@c.GetProperty("id").GetInt32()">@c.GetProperty("firstName").GetString() @c.GetProperty("lastName").GetString() — @c.GetProperty("nationalId").GetString()</option>
                        }
                    }
                </select>
            </div>

            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="form-label-small">PRODUCTO Y ASESOR</div>
                    <label style="color: #8b94a5; font-size: 0.85rem; margin-bottom: 5px;">Producto Financiero *</label>
                    <select asp-for="FinancialProductId" class="form-control-dark" required>
                        <option value="" disabled selected>Selecciona producto...</option>
                        @if (ViewBag.Products != null)
                        {
                            var prods = JsonDocument.Parse(ViewBag.Products.ToString()).RootElement.EnumerateArray();
                            foreach (var p in prods)
                            {
                                <option value="@p.GetProperty("id").GetInt32()">@p.GetProperty("productName").GetString()</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <div class="form-label-small">&nbsp;</div> <label style="color: #8b94a5; font-size: 0.85rem; margin-bottom: 5px;">Empleado Asesor *</label>
                    <select asp-for="EmployeeId" class="form-control-dark" required>
                        <option value="" disabled selected>Selecciona empleado...</option>
                        @if (ViewBag.Employees != null)
                        {
                            var emps = JsonDocument.Parse(ViewBag.Employees.ToString()).RootElement.EnumerateArray();
                            foreach (var e in emps)
                            {
                                <option value="@e.GetProperty("id").GetInt32()">@e.GetProperty("firstName").GetString() @e.GetProperty("lastName").GetString()</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="form-label-small">DATOS DE LA CUENTA</div>
                    <label style="color: #8b94a5; font-size: 0.85rem; margin-bottom: 5px;">Número de cuenta</label>
                    <div class="form-control-dark" style="cursor: default; opacity: 0.95;">
                        <span style="color: #93c5fd;">Asignación automática</span>
                        <div style="font-size: 0.8rem; color: #6b7280; margin-top: 6px; line-height: 1.4;">
                            Se generará al guardar con la nomenclatura <strong style="color:#a5b4fc;">BR</strong> + código de cliente + <strong style="color:#a5b4fc;">P</strong> + producto financiero + sufijo único (ej. <code style="color:#e5e7eb;">BR0042P0007A3F9E2</code>).
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-label-small">&nbsp;</div>
                    <label style="color: #8b94a5; font-size: 0.85rem; margin-bottom: 5px;">Monto Inicial (DOP) *</label>
                    <input asp-for="Amount" type="number" step="0.01" class="form-control-dark" placeholder="DOP 50,000.00" required />
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="form-label-small">FECHAS</div>
                    <label style="color: #8b94a5; font-size: 0.85rem; margin-bottom: 5px;">Fecha de Apertura *</label>
                    <input asp-for="OpenDate" type="date" class="form-control-dark" required />
                </div>
                <div class="col-md-6">
                    <div class="form-label-small">&nbsp;</div>
                    <label style="color: #8b94a5; font-size: 0.85rem; margin-bottom: 5px;">Fecha de Vencimiento</label>
                    <input asp-for="MaturityDate" type="date" class="form-control-dark" />
                </div>
            </div>

            <div class="mb-4">
                <label style="color: #3b82f6; font-size: 0.75rem; font-weight: 700; margin-bottom: 8px;">ESTADO INICIAL</label>
                <div class="status-group">
                    <div class="status-option">
                        <input type="radio" asp-for="Status" id="statusActive" value="activo" checked>
                        <label for="statusActive">Activo</label>
                    </div>
                    <div class="status-option">
                        <input type="radio" asp-for="Status" id="statusClosed" value="cerrado">
                        <label for="statusClosed">Cerrado</label>
                    </div>
                    <div class="status-option">
                        <input type="radio" asp-for="Status" id="statusSuspended" value="suspendido">
                        <label for="statusSuspended">Suspendido</label>
                    </div>
                    <div class="status-option">
                        <input type="radio" asp-for="Status" id="statusPending" value="pendiente">
                        <label for="statusPending">Pendiente</label>
                    </div>
                </div>
            </div>

            <div class="info-box">
                El número de cuenta lo genera el sistema de forma única; no hace falta escribirlo.
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <div style="color: #6b7280; font-size: 0.8rem;">* Campos obligatorios</div>
                <div class="d-flex gap-3">
                    <a asp-action="Index" class="btn-cancel">Cancelar</a>
                    <button type="submit" class="btn-create">Crear Contrato &rarr;</button>
                </div>
            </div>
        </form>
    </div>
</div>