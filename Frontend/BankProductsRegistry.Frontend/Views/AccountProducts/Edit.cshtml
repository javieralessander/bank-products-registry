@using System.Text.Json
@model BankProductsRegistry.Frontend.Models.AccountProductEditViewModel
@{
    ViewData["Title"] = "Editar Producto Contratado";
}

<style>
    /* ... (COPIA EXACTAMENTE EL MISMO BLOQUE <style> DE TU ARCHIVO Create.cshtml AQUÍ) ... */
    body {
        background-color: #0b0f19 !important;
    }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(0, 0, 0, 0.7);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .custom-modal {
        background-color: #151928;
        border-radius: 16px;
        border: 1px solid #2d3348;
        width: 100%;
        max-width: 800px;
        padding: 30px 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }

    .modal-header-custom {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 25px;
        border-bottom: 1px solid #2d3348;
        padding-bottom: 15px;
    }

    .modal-title {
        font-size: 1.4rem;
        font-weight: 600;
        color: white;
        margin: 0;
    }

    .modal-subtitle {
        color: #8b94a5;
        font-size: 0.9rem;
        margin-top: 5px;
    }

    .close-btn {
        background: transparent;
        border: none;
        color: #6b7280;
        font-size: 1.2rem;
        cursor: pointer;
        transition: 0.2s;
    }

        .close-btn:hover {
            color: white;
            text-decoration: none;
        }

    .form-label-small {
        color: #3b82f6;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 8px;
        letter-spacing: 0.5px;
    }
    /* Color amarillo para editar */
    .form-control-dark {
        background-color: #0f111a;
        border: 1px solid #2d3348;
        color: white;
        padding: 12px 15px;
        border-radius: 8px;
        font-size: 0.95rem;
        width: 100%;
    }

        .form-control-dark:focus {
            border-color: #3b82f6;
            outline: none;
            box-shadow: 0 0 0 2px rgba(59,130,246,0.2);
        }

    .status-group {
        display: flex;
        background-color: #0f111a;
        border-radius: 8px;
        border: 1px solid #2d3348;
        overflow: hidden;
    }

    .status-option {
        flex: 1;
        text-align: center;
    }

        .status-option input[type="radio"]:checked + label {
            background-color: #3b82f6;
            color: white;
        }

        .status-option label {
            display: block;
            padding: 12px;
            color: #8b94a5;
            cursor: pointer;
            font-weight: 500;
            font-size: 0.9rem;
            transition: 0.2s;
            margin: 0;
        }

        .status-option input[type="radio"]:checked + label {
            background-color: #eab308;
            color: #111;
        }

    .btn-create {
        background-color: #3b82f6;
        border: none;
        padding: 12px 25px;
        border-radius: 8px;
        color: white;
        font-weight: 600;
        transition: 0.2s;
    }

        .btn-create:hover {
            background-color: #2563eb;
        }

    .btn-cancel {
        background: transparent;
        border: none;
        color: #8b94a5;
        font-weight: 600;
        padding: 12px 25px;
        text-decoration: none;
        transition: 0.2s;
    }

        .btn-cancel:hover {
            color: white;
        }
</style>

<div class="modal-overlay">
    <div class="custom-modal">
        <div class="modal-header-custom">
            <div>
                <h2 class="modal-title">Editar Contrato #@Model.Id</h2>
                <div class="modal-subtitle">Actualiza los datos de la cuenta o servicio</div>
            </div>
            <a href="@Url.Action("Index")" class="close-btn">&times;</a>
        </div>

            @if (ViewBag.ErrorMessage != null)
            {
            <div class="alert alert-danger" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); margin-bottom: 20px;">
                    @ViewBag.ErrorMessage
            </div>
            }

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-4">
                <div class="form-label-small">CLIENTE</div>
                <select asp-for="ClientId" class="form-control-dark" required>
                    <option value="" disabled>Selecciona un cliente...</option>
                        @if (ViewBag.Clients != null)
                        {
                            var clients = JsonDocument.Parse(ViewBag.Clients.ToString()).RootElement.EnumerateArray();
                            foreach (var c in clients)
                            {
                            <option value="@c.GetProperty("id").GetInt32()">@c.GetProperty("firstName").GetString() @c.GetProperty("lastName").GetString()</option>
                            }
                        }
                </select>
            </div>

            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="form-label-small">PRODUCTO</div>
                    <select asp-for="FinancialProductId" class="form-control-dark" required>
                        <option value="" disabled>Selecciona producto...</option>
                            @if (ViewBag.Products != null)
                            {
                                var prods = JsonDocument.Parse(ViewBag.Products.ToString()).RootElement.EnumerateArray();
                                foreach (var p in prods)
                                {
                                <option value="@p.GetProperty("id").GetInt32()">@p.GetProperty("productName").GetString()</option>
                                }
                            }
                    </select>
                </div>
                <div class="col-md-6">
                    <div class="form-label-small">ASESOR</div>
                    <select asp-for="EmployeeId" class="form-control-dark" required>
                        <option value="" disabled>Selecciona empleado...</option>
                            @if (ViewBag.Employees != null)
                            {
                                var emps = JsonDocument.Parse(ViewBag.Employees.ToString()).RootElement.EnumerateArray();
                                foreach (var e in emps)
                                {
                                <option value="@e.GetProperty("id").GetInt32()">@e.GetProperty("firstName").GetString() @e.GetProperty("lastName").GetString()</option>
                                }
                            }
                    </select>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="form-label-small">N° DE CUENTA</div>
                    <input asp-for="AccountNumber" class="form-control-dark" required />
                </div>
                <div class="col-md-6">
                    <div class="form-label-small">MONTO (DOP)</div>
                    <input asp-for="Amount" type="number" step="0.01" class="form-control-dark" required />
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="form-label-small">APERTURA</div>
                    <input asp-for="OpenDate" type="date" class="form-control-dark" required />
                </div>
                <div class="col-md-6">
                    <div class="form-label-small">VENCIMIENTO</div>
                    <input asp-for="MaturityDate" type="date" class="form-control-dark" />
                </div>
            </div>

            <div class="mb-4">
                <label style="color: #eab308; font-size: 0.75rem; font-weight: 700; margin-bottom: 8px;">ESTADO OPERATIVO</label>
                <div class="status-group">
                    <div class="status-option"><input type="radio" asp-for="Status" id="sActive" value="activo"><label for="sActive">Activo</label></div>
                    <div class="status-option"><input type="radio" asp-for="Status" id="sClosed" value="cerrado"><label for="sClosed">Cerrado</label></div>
                    <div class="status-option"><input type="radio" asp-for="Status" id="sSuspended" value="suspendido"><label for="sSuspended">Suspendido</label></div>
                    <div class="status-option"><input type="radio" asp-for="Status" id="sDelinquent" value="en_mora"><label for="sDelinquent">En Mora</label></div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-3 mt-4">
                <a asp-action="Index" class="btn-cancel">Cancelar</a>
                <button type="submit" class="btn-create">Actualizar Contrato</button>
            </div>
        </form>
    </div>
</div>