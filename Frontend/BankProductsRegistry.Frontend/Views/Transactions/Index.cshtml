@model BankProductsRegistry.Frontend.Models.TransactionDashboardViewModel
@{
    ViewData["Title"] = "Transacciones";
}

<style>
    /* Estilos Generales */
    .page-header {
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 4px;
        color: white;
    }

    .page-subtitle {
        color: #8b94a5;
        font-size: 0.9rem;
    }

    .search-input-top {
        background-color: #1a1d2d;
        border: 1px solid #2d3348;
        color: white;
        border-radius: 8px;
        padding: 10px 16px;
        width: 250px;
        outline: none;
        transition: 0.3s;
    }

        .search-input-top:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 2px rgba(59,130,246,0.2);
        }

    /* Tarjetas de Resumen */
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .summary-card {
        background-color: #1a1d2d;
        border-radius: 12px;
        border: 1px solid #2d3348;
        padding: 20px;
    }

    .card-border-green {
        border-left: 4px solid #10b981;
    }

    .card-border-red {
        border-left: 4px solid #ef4444;
    }

    .card-border-blue {
        border-left: 4px solid #3b82f6;
    }

    .summary-label {
        color: #8b94a5;
        font-size: 0.85rem;
        margin-bottom: 8px;
        font-weight: 500;
    }

    .summary-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: white;
        line-height: 1;
    }

    /* Barra de Herramientas y Filtros */
    .toolbar {
        background-color: #1a1d2d;
        border: 1px solid #2d3348;
        border-radius: 12px 12px 0 0;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: none;
    }

    .search-inline {
        background-color: transparent;
        border: none;
        color: white;
        outline: none;
        width: 300px;
        font-size: 0.95rem;
    }

        .search-inline::placeholder {
            color: #6b7280;
        }

    .filter-tabs {
        display: flex;
        gap: 5px;
    }

    .f-tab {
        color: #8b94a5;
        font-size: 0.85rem;
        padding: 6px 16px;
        border-radius: 6px;
        cursor: pointer;
        transition: 0.2s;
        font-weight: 500;
    }

        .f-tab:hover {
            color: white;
            background-color: rgba(255,255,255,0.05);
        }

        .f-tab.active {
            background-color: #1e3a8a;
            color: #60a5fa;
        }

    /* Tabla de Transacciones */
    .table-container {
        background-color: #1a1d2d;
        border-radius: 0 0 12px 12px;
        border: 1px solid #2d3348;
        overflow-x: auto;
    }

    .custom-table {
        width: 100%;
        color: #d1d5db;
        font-size: 0.9rem;
        border-collapse: collapse;
    }

        .custom-table th {
            padding: 16px 20px;
            font-weight: 500;
            color: #8b94a5;
            border-bottom: 1px solid #2d3348;
            text-align: left;
        }

        .custom-table td {
            padding: 16px 20px;
            border-bottom: 1px solid #2d3348;
            vertical-align: middle;
        }

        .custom-table tr:hover {
            background-color: #1f2335;
        }

        .custom-table tr:last-child td {
            border-bottom: none;
        }

    /* Colores de texto y Badges */
    .text-green {
        color: #10b981;
        font-weight: 500;
    }

    .text-red {
        color: #ef4444;
        font-weight: 500;
    }

    .badge-success {
        background-color: rgba(16, 185, 129, 0.1);
        color: #10b981;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Transacciones</h1>
        <div class="page-subtitle">
            @if (User.IsInRole("Cliente"))
            {
                <text>Registra movimientos de demostración y consulta tu historial. En tarjetas de crédito, los cargos reales provienen de la red; aquí puedes simular un pago o abono para el flujo del sistema.</text>
            }
            else
            {
                <text>Historial completo de movimientos bancarios</text>
            }
        </div>
    </div>
    
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" style="background-color: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2); margin-bottom: 20px; padding: 12px; border-radius: 8px;">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); margin-bottom: 20px; padding: 12px; border-radius: 8px;">
        @TempData["ErrorMessage"]
    </div>
}

@if (User.IsInRole("Cliente"))
{
    <div class="card border-0 shadow-sm mb-4 bg-white rounded-3 p-4">
        <h2 class="h5 mb-3 text-dark">Registrar movimiento</h2>
        @if (Model.ClientAccounts == null || !Model.ClientAccounts.Any())
        {
            <p class="text-muted mb-0">No tienes productos activos para operar. Cuando un ejecutivo active un contrato, podrás registrar transferencias y otros movimientos simulados aquí.</p>
        }
        else
        {
            <form asp-action="RegisterTransfer" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <div class="col-md-6">
                    <label class="form-label small text-secondary">Producto / cuenta</label>
                    <select name="AccountProductId" class="form-select" required id="clientAccountSelect">
                        <option value="">— Selecciona —</option>
                        @foreach (var a in Model.ClientAccounts)
                        {
                            var isCard = !string.IsNullOrEmpty(a.FinancialProductName) &&
                                (a.FinancialProductName.Contains("tarjeta", StringComparison.OrdinalIgnoreCase) ||
                                 a.FinancialProductName.Contains("crédito", StringComparison.OrdinalIgnoreCase) ||
                                 a.FinancialProductName.Contains("credito", StringComparison.OrdinalIgnoreCase));
                            <option value="@a.Id" data-is-card="@(isCard ? "1" : "0")">@a.AccountNumber — @a.FinancialProductName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-secondary">Tipo de operación</label>
                    <select name="OperationKind" class="form-select" id="operationKindSelect">
                        <option value="transferencia">Transferencia (salida)</option>
                        <option value="pago">Pago / abono (simulado; útil en tarjeta)</option>
                        <option value="deposito">Depósito (entrada)</option>
                        <option value="retiro">Retiro (salida)</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-secondary">Monto (DOP)</label>
                    <input name="Amount" type="number" step="0.01" min="0.01" class="form-control" required placeholder="0.00" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-secondary">Referencia (opcional)</label>
                    <input name="ReferenceNumber" type="text" maxlength="60" class="form-control" placeholder="Ej. ref. banco destino" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-secondary">Nota (opcional)</label>
                    <input name="Description" type="text" maxlength="300" class="form-control" />
                </div>
                <div class="col-12">
                    <p class="small text-muted mb-2 d-none" id="cardHint">
                        <i class="bi bi-info-circle"></i> Producto tipo tarjeta: en producción los consumos llegan por la red de pagos; este registro es solo para demostrar el proceso en el sistema.
                    </p>
                    <button type="submit" class="btn btn-primary">Registrar movimiento</button>
                </div>
            </form>
            <script>
                (function () {
                    var sel = document.getElementById('clientAccountSelect');
                    var hint = document.getElementById('cardHint');
                    function sync() {
                        var opt = sel.options[sel.selectedIndex];
                        var isCard = opt && opt.getAttribute('data-is-card') === '1';
                        hint.classList.toggle('d-none', !isCard);
                    }
                    sel.addEventListener('change', sync);
                    sync();
                })();
            </script>
        }
    </div>

    <div class="card border-0 shadow-sm mb-4 bg-white rounded-3 p-4">
        <h2 class="h5 mb-2 text-dark">Exportar estado de cuenta (PDF)</h2>
        <p class="small text-muted mb-3">Descarga tus movimientos por periodo (formato tipo estado de cuenta).</p>
        @{
            var clientIdPdfClaim = User.Claims.FirstOrDefault(c => c.Type == "client_id")?.Value;
        }
        @if (!string.IsNullOrEmpty(clientIdPdfClaim) && int.TryParse(clientIdPdfClaim, out var clientIdForPdf))
        {
            var hoy = DateTime.Today;
            var desdeDefault = hoy.AddDays(-30);
            <form method="get" asp-controller="ReportsExport" asp-action="ClientTransactionStatementPdf" class="row g-3 align-items-end">
                <input type="hidden" name="clientId" value="@clientIdForPdf" />
                <div class="col-md-3">
                    <label class="form-label small text-secondary">Desde</label>
                    <input type="date" name="from" class="form-control" value="@desdeDefault.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-secondary">Hasta</label>
                    <input type="date" name="to" class="form-control" value="@hoy.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-secondary">Producto (opcional)</label>
                    <select name="accountProductId" class="form-select">
                        <option value="">Todos mis productos</option>
                        @if (Model.ClientAccounts != null)
                        {
                            foreach (var acc in Model.ClientAccounts)
                            {
                                <option value="@acc.Id">@acc.AccountNumber — @acc.FinancialProductName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary w-100">Descargar PDF</button>
                </div>
            </form>
        }
        else
        {
            <p class="text-muted mb-0 small">Tu sesión no tiene un perfil de cliente vinculado para exportar.</p>
        }
    </div>
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); margin-bottom: 20px;">
        @ViewBag.ErrorMessage
    </div>
}

<div class="summary-grid">
    <div class="summary-card card-border-green">
        <div class="summary-label">Total Depósitos</div>
        <div class="summary-value">DOP @(Model.TotalDeposits >= 1000000 ? (Model.TotalDeposits / 1000000).ToString("0.##") + "M" : Model.TotalDeposits >= 1000 ? (Model.TotalDeposits / 1000).ToString("0.##") + "K" : Model.TotalDeposits.ToString("N0"))</div>
    </div>
    <div class="summary-card card-border-red">
        <div class="summary-label">Total Retiros</div>
        <div class="summary-value">DOP @(Model.TotalWithdrawals >= 1000000 ? (Model.TotalWithdrawals / 1000000).ToString("0.##") + "M" : Model.TotalWithdrawals >= 1000 ? (Model.TotalWithdrawals / 1000).ToString("0.##") + "K" : Model.TotalWithdrawals.ToString("N0"))</div>
    </div>
    <div class="summary-card card-border-blue">
        <div class="summary-label">Balance Neto</div>
        <div class="summary-value">DOP @(Model.NetBalance >= 1000000 ? (Model.NetBalance / 1000000).ToString("0.##") + "M" : Model.NetBalance >= 1000 ? (Model.NetBalance / 1000).ToString("0.##") + "K" : Model.NetBalance.ToString("N0"))</div>
    </div>
</div>

<div class="toolbar">
    <input type="text" id="tableSearch" class="search-inline" placeholder="Buscar por cuenta, referencia..." />
    <div class="filter-tabs">
        <div class="f-tab active" data-filter="Todos">Todos</div>
        <div class="f-tab" data-filter="deposito">Depósito</div>
        <div class="f-tab" data-filter="retiro">Retiro</div>
    </div>
</div>

<div class="table-container">
    <table class="custom-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Cuenta</th>
                <th>Tipo</th>
                <th>Monto</th>
                <th>Fecha</th>
                <th>Descripción</th>
                <th>Referencia</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody id="transactionsBody">
            @if (!Model.Transactions.Any())
            {
                <tr>
                    <td colspan="8" class="text-center" style="padding: 40px; color: #8b94a5;">
                        No hay transacciones registradas en el sistema.
                    </td>
                </tr>
            }
            else
            {
                foreach (var tx in Model.Transactions)
                {
                    // Volvemos a leer el string que manda la API
                    var rawType = tx.TransactionType?.ToLower() ?? "";
                    bool isDeposit = rawType.Contains("deposito");

                    string typeDisplay = rawType switch
                    {
                        var t when t.Contains("deposito") => "Depósito",
                        var t when t.Contains("retiro") => "Retiro",
                        var t when t.Contains("transferencia") => "Transferencia",
                        var t when t.Contains("pago") => "Pago",
                        var t when t.Contains("cargo") => "Cargo",
                        _ => tx.TransactionType ?? "Desconocido"
                    };

                    string dataFilterType = isDeposit ? "deposito" : "retiro";

                    <tr class="tx-row" data-type="@dataFilterType">
                        <td style="color: #6b7280;">T-@tx.Id.ToString("D3")</td>
                        <td style="color: white; font-weight: 500;">@tx.AccountNumber</td>
                        <td class="@(isDeposit ? "text-green" : "text-red")">@typeDisplay</td>
                        <td style="color: white;">DOP @tx.Amount.ToString("N2")</td>
                        <td>@tx.TransactionDate.ToString("dd/MM HH:mm")</td>
                        <td>@(string.IsNullOrEmpty(tx.Description) ? "-" : tx.Description)</td>
                        <td style="color: #8b94a5;">@(string.IsNullOrEmpty(tx.ReferenceNumber) ? "-" : tx.ReferenceNumber)</td>
                        <td><span class="badge-success">Completada</span></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<script>
    // Filtro por pestañas
    const tabs = document.querySelectorAll('.f-tab');
    const rows = document.querySelectorAll('.tx-row');

    tabs.forEach(tab => {
        tab.addEventListener('click', function() {
            tabs.forEach(t => t.classList.remove('active'));
            this.classList.add('active');

            const filter = this.getAttribute('data-filter');

            rows.forEach(row => {
                // Si el filtro es retiro, vamos a incluir pagos y cargos también como "salidas"
                const rowType = row.getAttribute('data-type');
                const isWithdrawalFamily = rowType === 'retiro' || rowType === 'pago' || rowType === 'cargo' || rowType === 'transferencia';

                if (filter === 'Todos' ||
                   (filter === 'deposito' && rowType === 'deposito') ||
                   (filter === 'retiro' && isWithdrawalFamily)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    });

    // Buscador en tiempo real por Cuenta, Referencia o Descripción
    document.getElementById('tableSearch').addEventListener('keyup', function () {
        const searchValue = this.value.toLowerCase();

        rows.forEach(row => {
            const textContent = row.textContent.toLowerCase();
            const activeFilter = document.querySelector('.f-tab.active').getAttribute('data-filter');

            const rowType = row.getAttribute('data-type');
            const isWithdrawalFamily = rowType === 'retiro' || rowType === 'pago' || rowType === 'cargo' || rowType === 'transferencia';

            const matchFilter = activeFilter === 'Todos' ||
                               (activeFilter === 'deposito' && rowType === 'deposito') ||
                               (activeFilter === 'retiro' && isWithdrawalFamily);

            if (textContent.includes(searchValue) && matchFilter) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });
</script>