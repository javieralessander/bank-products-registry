@model BankProductsRegistry.Frontend.Models.TransactionDashboardViewModel
@{
    ViewData["Title"] = "Transacciones";
}

<style>
    /* Estilos Generales */
    .page-header {
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 4px;
        color: white;
    }

    .page-subtitle {
        color: #8b94a5;
        font-size: 0.9rem;
    }

    .search-input-top {
        background-color: #1a1d2d;
        border: 1px solid #2d3348;
        color: white;
        border-radius: 8px;
        padding: 10px 16px;
        width: 250px;
        outline: none;
        transition: 0.3s;
    }

        .search-input-top:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 2px rgba(59,130,246,0.2);
        }

    /* Tarjetas de Resumen */
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .summary-card {
        background-color: #1a1d2d;
        border-radius: 12px;
        border: 1px solid #2d3348;
        padding: 20px;
    }

    .card-border-green {
        border-left: 4px solid #10b981;
    }

    .card-border-red {
        border-left: 4px solid #ef4444;
    }

    .card-border-blue {
        border-left: 4px solid #3b82f6;
    }

    .summary-label {
        color: #8b94a5;
        font-size: 0.85rem;
        margin-bottom: 8px;
        font-weight: 500;
    }

    .summary-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: white;
        line-height: 1;
    }

    /* Barra de Herramientas y Filtros */
    .toolbar {
        background-color: #1a1d2d;
        border: 1px solid #2d3348;
        border-radius: 12px 12px 0 0;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: none;
    }

    .search-inline {
        background-color: transparent;
        border: none;
        color: white;
        outline: none;
        width: 300px;
        font-size: 0.95rem;
    }

        .search-inline::placeholder {
            color: #6b7280;
        }

    .filter-tabs {
        display: flex;
        gap: 5px;
    }

    .f-tab {
        color: #8b94a5;
        font-size: 0.85rem;
        padding: 6px 16px;
        border-radius: 6px;
        cursor: pointer;
        transition: 0.2s;
        font-weight: 500;
    }

        .f-tab:hover {
            color: white;
            background-color: rgba(255,255,255,0.05);
        }

        .f-tab.active {
            background-color: #1e3a8a;
            color: #60a5fa;
        }

    /* Tabla de Transacciones */
    .table-container {
        background-color: #1a1d2d;
        border-radius: 0 0 12px 12px;
        border: 1px solid #2d3348;
        overflow-x: auto;
    }

    .custom-table {
        width: 100%;
        color: #d1d5db;
        font-size: 0.9rem;
        border-collapse: collapse;
    }

        .custom-table th {
            padding: 16px 20px;
            font-weight: 500;
            color: #8b94a5;
            border-bottom: 1px solid #2d3348;
            text-align: left;
        }

        .custom-table td {
            padding: 16px 20px;
            border-bottom: 1px solid #2d3348;
            vertical-align: middle;
        }

        .custom-table tr:hover {
            background-color: #1f2335;
        }

        .custom-table tr:last-child td {
            border-bottom: none;
        }

    /* Colores de texto y Badges */
    .text-green {
        color: #10b981;
        font-weight: 500;
    }

    .text-red {
        color: #ef4444;
        font-weight: 500;
    }

    .badge-success {
        background-color: rgba(16, 185, 129, 0.1);
        color: #10b981;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Transacciones</h1>
        <div class="page-subtitle">Historial completo de movimientos bancarios</div>
    </div>
    
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); margin-bottom: 20px;">
        @ViewBag.ErrorMessage
    </div>
}

<div class="summary-grid">
    <div class="summary-card card-border-green">
        <div class="summary-label">Total Depósitos</div>
        <div class="summary-value">DOP @(Model.TotalDeposits >= 1000000 ? (Model.TotalDeposits / 1000000).ToString("0.##") + "M" : Model.TotalDeposits >= 1000 ? (Model.TotalDeposits / 1000).ToString("0.##") + "K" : Model.TotalDeposits.ToString("N0"))</div>
    </div>
    <div class="summary-card card-border-red">
        <div class="summary-label">Total Retiros</div>
        <div class="summary-value">DOP @(Model.TotalWithdrawals >= 1000000 ? (Model.TotalWithdrawals / 1000000).ToString("0.##") + "M" : Model.TotalWithdrawals >= 1000 ? (Model.TotalWithdrawals / 1000).ToString("0.##") + "K" : Model.TotalWithdrawals.ToString("N0"))</div>
    </div>
    <div class="summary-card card-border-blue">
        <div class="summary-label">Balance Neto</div>
        <div class="summary-value">DOP @(Model.NetBalance >= 1000000 ? (Model.NetBalance / 1000000).ToString("0.##") + "M" : Model.NetBalance >= 1000 ? (Model.NetBalance / 1000).ToString("0.##") + "K" : Model.NetBalance.ToString("N0"))</div>
    </div>
</div>

<div class="toolbar">
    <input type="text" id="tableSearch" class="search-inline" placeholder="Buscar por cuenta, referencia..." />
    <div class="filter-tabs">
        <div class="f-tab active" data-filter="Todos">Todos</div>
        <div class="f-tab" data-filter="deposito">Depósito</div>
        <div class="f-tab" data-filter="retiro">Retiro</div>
    </div>
</div>

<div class="table-container">
    <table class="custom-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Cuenta</th>
                <th>Tipo</th>
                <th>Monto</th>
                <th>Fecha</th>
                <th>Descripción</th>
                <th>Referencia</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody id="transactionsBody">
            @if (!Model.Transactions.Any())
            {
                <tr>
                    <td colspan="8" class="text-center" style="padding: 40px; color: #8b94a5;">
                        No hay transacciones registradas en el sistema.
                    </td>
                </tr>
            }
            else
            {
                foreach (var tx in Model.Transactions)
                {
                    // Volvemos a leer el string que manda la API
                    var rawType = tx.TransactionType?.ToLower() ?? "";
                    bool isDeposit = rawType.Contains("deposito");

                    string typeDisplay = rawType switch
                    {
                        var t when t.Contains("deposito") => "Depósito",
                        var t when t.Contains("retiro") => "Retiro",
                        var t when t.Contains("transferencia") => "Transferencia",
                        var t when t.Contains("pago") => "Pago",
                        var t when t.Contains("cargo") => "Cargo",
                        _ => tx.TransactionType ?? "Desconocido"
                    };

                    string dataFilterType = isDeposit ? "deposito" : "retiro";

                    <tr class="tx-row" data-type="@dataFilterType">
                        <td style="color: #6b7280;">T-@tx.Id.ToString("D3")</td>
                        <td style="color: white; font-weight: 500;">@tx.AccountNumber</td>
                        <td class="@(isDeposit ? "text-green" : "text-red")">@typeDisplay</td>
                        <td style="color: white;">DOP @tx.Amount.ToString("N2")</td>
                        <td>@tx.TransactionDate.ToString("dd/MM HH:mm")</td>
                        <td>@(string.IsNullOrEmpty(tx.Description) ? "-" : tx.Description)</td>
                        <td style="color: #8b94a5;">@(string.IsNullOrEmpty(tx.ReferenceNumber) ? "-" : tx.ReferenceNumber)</td>
                        <td><span class="badge-success">Completada</span></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<script>
    // Filtro por pestañas
    const tabs = document.querySelectorAll('.f-tab');
    const rows = document.querySelectorAll('.tx-row');

    tabs.forEach(tab => {
        tab.addEventListener('click', function() {
            tabs.forEach(t => t.classList.remove('active'));
            this.classList.add('active');

            const filter = this.getAttribute('data-filter');

            rows.forEach(row => {
                // Si el filtro es retiro, vamos a incluir pagos y cargos también como "salidas"
                const rowType = row.getAttribute('data-type');
                const isWithdrawalFamily = rowType === 'retiro' || rowType === 'pago' || rowType === 'cargo' || rowType === 'transferencia';

                if (filter === 'Todos' ||
                   (filter === 'deposito' && rowType === 'deposito') ||
                   (filter === 'retiro' && isWithdrawalFamily)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    });

    // Buscador en tiempo real por Cuenta, Referencia o Descripción
    document.getElementById('tableSearch').addEventListener('keyup', function () {
        const searchValue = this.value.toLowerCase();

        rows.forEach(row => {
            const textContent = row.textContent.toLowerCase();
            const activeFilter = document.querySelector('.f-tab.active').getAttribute('data-filter');

            const rowType = row.getAttribute('data-type');
            const isWithdrawalFamily = rowType === 'retiro' || rowType === 'pago' || rowType === 'cargo' || rowType === 'transferencia';

            const matchFilter = activeFilter === 'Todos' ||
                               (activeFilter === 'deposito' && rowType === 'deposito') ||
                               (activeFilter === 'retiro' && isWithdrawalFamily);

            if (textContent.includes(searchValue) && matchFilter) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });
</script>