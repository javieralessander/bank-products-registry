@model BankProductsRegistry.Frontend.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<style>
    /* El truco principal: forzar el color oscuro en las tarjetas */
    .custom-card {
        background-color: #1a1d2d;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        padding: 20px;
        border: 1px solid #2d3348;
    }

    /* Bordes superiores de colores */
    .card-top-clientes {
        border-top: 4px solid #3b82f6;
    }

    .card-top-productos {
        border-top: 4px solid #10b981;
    }

    .card-top-transacciones {
        border-top: 4px solid #f59e0b;
    }

    .card-top-volumen {
        border-top: 4px solid #ef4444;
    }

    /* Textos de las tarjetas */
    .stat-title {
        color: #8b94a5;
        font-size: 0.85rem;
        margin-bottom: 5px;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: bold;
        color: #ffffff;
        line-height: 1.2;
        margin-bottom: 5px;
    }

    .stat-desc {
        color: #8b94a5;
        font-size: 0.75rem;
    }

    /* Buscador superior */
    .search-input {
        background-color: #1a1d2d;
        border: 1px solid #2d3348;
        color: white;
        border-radius: 8px;
        padding: 8px 16px;
        width: 250px;
        outline: none;
    }

        .search-input::placeholder {
            color: #8b94a5;
        }

    /* Tabla transparente para que tome el color oscuro de la tarjeta */
    .table-dark-custom {
        --bs-table-bg: transparent; /* Anula el fondo blanco por defecto de Bootstrap */
        color: #a0aabf;
        margin-bottom: 0;
    }

        /* Forzamos a que las filas y celdas sean transparentes */
        .table-dark-custom tr, .table-dark-custom th, .table-dark-custom td {
            background-color: transparent !important;
        }

        .table-dark-custom th {
            border-bottom: 1px solid #2d3348;
            color: #8b94a5;
            font-weight: normal;
            padding: 10px 0;
            font-size: 0.9rem;
        }

        .table-dark-custom td {
            border-bottom: 1px solid #2d3348;
            padding: 15px 0;
            vertical-align: middle;
            color: #ffffff;
        }

        .table-dark-custom tr:last-child td {
            border-bottom: none;
        }

    /* Etiquetas de Estado */
    .badge-success {
        background-color: rgba(16, 185, 129, 0.1);
        color: #10b981;
        border: 1px solid rgba(16, 185, 129, 0.2);
        font-weight: normal;
        padding: 5px 10px;
    }

    .badge-warning {
        background-color: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
        border: 1px solid rgba(245, 158, 11, 0.2);
        font-weight: normal;
        padding: 5px 10px;
    }

    .text-deposit {
        color: #10b981;
    }

    .text-withdrawal {
        color: #ef4444;
    }

    /* Barras de progreso de la derecha */
    .progress-custom {
        height: 6px;
        background-color: #2d3348;
        border-radius: 10px;
        margin-top: 8px;
    }

    .text-green {
        color: #10b981 !important;
        font-weight: 500;
    }

    .text-red {
        color: #ef4444 !important;
        font-weight: 500;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="text-white fw-bold mb-1">Dashboard</h3>
        <div style="color: #8b94a5; font-size: 0.9rem;">Bienvenido, aquí está el resumen del sistema</div>
    </div>
    <div>
        <input type="text" class="search-input" placeholder="Buscar...">
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="custom-card card-top-clientes">
            <div class="stat-title">Total Clientes</div>
            <div class="stat-value">@Model.TotalClients.ToString("N0")</div>
            <div class="stat-desc">Usuarios en el sistema</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="custom-card card-top-productos">
            <div class="stat-title">Productos Activos</div>
            <div class="stat-value">@Model.ActiveProducts.ToString("N0")</div>
            <div class="stat-desc">Cuentas y servicios operativos</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="custom-card card-top-transacciones">
            <div class="stat-title">Transacciones</div>
            <div class="stat-value">@Model.TotalTransactions.ToString("N0")</div>
            <div class="stat-desc">Registradas históricamente</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="custom-card card-top-volumen">
            <div class="stat-title">Vol. Colocado</div>
            <div class="stat-value">DOP @((Model.TotalVolume / 1000000).ToString("0.0"))M</div>
            <div class="stat-desc">Capital total manejado</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="custom-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="text-white fw-bold m-0">Transacciones Recientes</h6>
                <a href="#" class="text-decoration-none" style="color: #3b82f6; font-size: 0.85rem;">Ver todas &rarr;</a>
            </div>
            <table class="table table-borderless table-dark-custom w-100 m-0">
                <thead>
                    <tr>
                        <th>Cliente / Producto</th>
                        <th>Tipo</th>
                        <th>Monto</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentTransactions == null || !Model.RecentTransactions.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center" style="padding: 30px; color: #8b94a5;">
                                Aún no hay transacciones registradas.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var tx in Model.RecentTransactions)
                        {
                            // Como la API del Dashboard nos manda el Enum convertido a texto ("Deposit", "Withdrawal")
                            var rawType = tx.TransactionType.ToLower();
                            var esDeposito = rawType.Contains("deposit") || rawType.Contains("depósito");

                            string typeDisplay = esDeposito ? "Depósito" : "Retiro";

                            <tr>
                                <td>
                                    <div style="color: white; font-weight: 500;">@tx.ClientName</div>
                                    <div style="font-size: 0.8rem; color: #8b94a5;">@tx.ProductName</div>
                                </td>
                                <td class="@(esDeposito ? "text-green" : "text-red")">
                                    @typeDisplay
                                </td>
                                <td style="color: white;">DOP @tx.Amount.ToString("N2")</td>
                                <td style="color: #8b94a5;">@tx.Date.ToString("dd/MM/yy HH:mm")</td>
                                <td>
                                    <span class="badge rounded-pill badge-success">Completada</span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="col-md-4">
        <div class="custom-card h-100">
            <h6 class="text-white fw-bold mb-4">Tipos de Producto</h6>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem; color: #8b94a5;">
                    <span>Tarjeta Crédito</span>
                    <span class="text-white">32%</span>
                </div>
                <div class="progress progress-custom">
                    <div class="progress-bar" style="width: 32%; background-color: #3b82f6;"></div>
                </div>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem; color: #8b94a5;">
                    <span>Préstamo</span>
                    <span class="text-white">28%</span>
                </div>
                <div class="progress progress-custom">
                    <div class="progress-bar" style="width: 28%; background-color: #ef4444;"></div>
                </div>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem; color: #8b94a5;">
                    <span>Inversión</span>
                    <span class="text-white">20%</span>
                </div>
                <div class="progress progress-custom">
                    <div class="progress-bar" style="width: 20%; background-color: #10b981;"></div>
                </div>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem; color: #8b94a5;">
                    <span>Certificado</span>
                    <span class="text-white">12%</span>
                </div>
                <div class="progress progress-custom">
                    <div class="progress-bar" style="width: 12%; background-color: #f59e0b;"></div>
                </div>
            </div>

            <div class="mb-2">
                <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem; color: #8b94a5;">
                    <span>Cta. Ahorro</span>
                    <span class="text-white">8%</span>
                </div>
                <div class="progress progress-custom">
                    <div class="progress-bar" style="width: 8%; background-color: #8b5cf6;"></div>
                </div>
            </div>
        </div>
    </div>
</div>