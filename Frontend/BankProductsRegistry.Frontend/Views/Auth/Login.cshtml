@model BankProductsRegistry.Frontend.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BankRED - Iniciar Sesión</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            color: #ffffff;
            background: linear-gradient(135deg, #0f111a 0%, #151b2b 50%, #0f111a 100%);
            position: relative;
            overflow: hidden;
        }

            body::before {
                content: "";
                position: absolute;
                top: -20%;
                left: -10%;
                width: 60%;
                height: 60%;
                background: radial-gradient(circle, rgba(59, 130, 246, 0.12) 0%, transparent 60%);
                z-index: 0;
            }

            body::after {
                content: "";
                position: absolute;
                bottom: -20%;
                right: -10%;
                width: 60%;
                height: 60%;
                background: radial-gradient(circle, rgba(16, 185, 129, 0.08) 0%, transparent 60%);
                z-index: 0;
            }

        .auth-card {
            background: rgba(26, 29, 45, 0.65);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.6);
            padding: 40px;
            width: 100%;
            max-width: 420px;
            position: relative;
            z-index: 1;
        }

        .input-group-custom {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-icon {
            position: absolute;
            left: 15px;
            color: #6b7280;
            font-size: 1.1rem;
            z-index: 10;
        }

        .form-control {
            background-color: rgba(15, 17, 26, 0.7);
            border: 1px solid #2d3348;
            color: white;
            padding: 12px 16px 12px 45px;
            border-radius: 10px;
            transition: 0.3s;
        }

            .form-control:focus {
                background-color: rgba(21, 25, 40, 0.9);
                color: white;
                border-color: #3b82f6;
                box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25);
            }

            .form-control::placeholder {
                color: #6b7280;
            }

        .btn-primary-custom {
            background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%);
            border: none;
            padding: 12px;
            font-weight: 600;
            border-radius: 10px;
            width: 100%;
            color: white;
            transition: 0.3s;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
        }

            .btn-primary-custom:hover {
                background: linear-gradient(180deg, #60a5fa 0%, #3b82f6 100%);
                transform: translateY(-2px);
                box-shadow: 0 6px 18px rgba(37, 99, 235, 0.35);
                color: white;
            }

        .btn-outline-custom {
            background: transparent;
            border: 1px solid #2d3348;
            padding: 12px;
            font-weight: 600;
            border-radius: 10px;
            width: 100%;
            color: #8b94a5;
            transition: 0.3s;
            text-decoration: none;
            display: block;
            text-align: center;
        }

            .btn-outline-custom:hover {
                background: #1a1d2d;
                color: white;
                border-color: #4b5563;
            }

        .brand-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 5px;
            letter-spacing: -0.5px;
        }

            .brand-logo span.text-blue {
                color: #3b82f6;
            }

        .auth-link {
            color: #60a5fa;
            text-decoration: none;
            font-weight: 500;
            transition: 0.3s;
        }

            .auth-link:hover {
                color: #93c5fd;
                text-decoration: underline;
            }

        .back-link {
            position: absolute;
            top: -40px;
            left: 0;
            color: #8b94a5;
            text-decoration: none;
            font-size: 0.9rem;
            transition: 0.2s;
        }

            .back-link:hover {
                color: white;
            }
    </style>
</head>
<body>
    <div style="position: relative; z-index: 1;">
        <a href="@Url.Action("Index", "Home")" class="back-link"><i class="bi bi-arrow-left"></i> Volver al inicio</a>

        <div class="auth-card">
            <div class="brand-logo">Bank<span class="text-blue">RED</span></div>
            <p class="text-center text-muted mb-4" style="font-size: 0.95rem;">Acceso seguro a tu banca digital</p>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success d-flex align-items-center gap-2" style="background-color: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); font-size: 0.9rem; border-radius: 10px;">
                    <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
                </div>
            }

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger d-flex align-items-center gap-2" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); font-size: 0.9rem; border-radius: 10px;">
                    <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.ErrorMessage
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label text-muted" style="font-size: 0.85rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Usuario o Correo</label>
                    <div class="input-group-custom">
                        <i class="bi bi-person input-icon"></i>
                        <input asp-for="UserNameOrEmail" class="form-control" placeholder="admin o correo@bank.local" />
                    </div>
                    <span asp-validation-for="UserNameOrEmail" class="text-danger mt-1 d-block" style="font-size: 0.8rem;"></span>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <label class="form-label text-muted m-0" style="font-size: 0.85rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Contraseña</label>
                        <a href="#" class="auth-link" style="font-size: 0.85rem;">¿Olvidaste tu clave?</a>
                    </div>
                    <div class="input-group-custom">
                        <i class="bi bi-lock input-icon"></i>
                        <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger mt-1 d-block" style="font-size: 0.8rem;"></span>
                </div>

                <button type="submit" class="btn-primary-custom mb-3">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Iniciar Sesión
                </button>

                <div class="position-relative text-center my-4">
                    <hr style="border-color: #2d3348;" />
                    <span class="text-muted px-2" style="background: rgba(26, 29, 45, 1); position: absolute; top: -11px; left: 50%; transform: translateX(-50%); font-size: 0.85rem;">o</span>
                </div>

                <a asp-action="Register" asp-controller="Auth" class="btn-outline-custom">
                    Crear nueva cuenta
                </a>
            </form>
        </div>
    </div>
</body>
</html>