@model BankProductsRegistry.Frontend.Models.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BankRED - Crear Cuenta</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            color: #ffffff;
            background: linear-gradient(135deg, #0f111a 0%, #151b2b 50%, #0f111a 100%);
            position: relative;
            overflow-x: hidden;
            padding: 40px 0;
        }

            body::before {
                content: "";
                position: absolute;
                top: -10%;
                right: -10%;
                width: 60%;
                height: 60%;
                background: radial-gradient(circle, rgba(16, 185, 129, 0.08) 0%, transparent 60%);
                z-index: 0;
            }

            body::after {
                content: "";
                position: absolute;
                bottom: -10%;
                left: -10%;
                width: 60%;
                height: 60%;
                background: radial-gradient(circle, rgba(59, 130, 246, 0.12) 0%, transparent 60%);
                z-index: 0;
            }

        .auth-card {
            background: rgba(26, 29, 45, 0.65);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.6);
            padding: 40px;
            width: 100%;
            max-width: 550px;
            position: relative;
            z-index: 1;
        }

        .input-group-custom {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-icon {
            position: absolute;
            left: 15px;
            color: #6b7280;
            font-size: 1.1rem;
            z-index: 10;
        }

        .form-control {
            background-color: rgba(15, 17, 26, 0.7);
            border: 1px solid #2d3348;
            color: white;
            padding: 10px 14px 10px 42px;
            border-radius: 10px;
            transition: 0.3s;
        }

            .form-control:focus {
                background-color: rgba(21, 25, 40, 0.9);
                color: white;
                border-color: #3b82f6;
                box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25);
            }

            .form-control::placeholder {
                color: #6b7280;
            }

        .btn-primary-custom {
            background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%);
            border: none;
            padding: 12px;
            font-weight: 600;
            border-radius: 10px;
            width: 100%;
            color: white;
            transition: 0.3s;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
        }

            .btn-primary-custom:hover {
                background: linear-gradient(180deg, #60a5fa 0%, #3b82f6 100%);
                transform: translateY(-2px);
                box-shadow: 0 6px 18px rgba(37, 99, 235, 0.35);
                color: white;
            }

        .brand-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 5px;
            letter-spacing: -0.5px;
        }

            .brand-logo span.text-blue {
                color: #3b82f6;
            }

        .auth-link {
            color: #60a5fa;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
        }

            .auth-link:hover {
                color: #93c5fd;
                text-decoration: underline;
            }

        .form-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: #8b94a5;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .auth-subtitle {
            color: #cbd5e1;
            font-size: 0.95rem;
            text-align: center;
            margin-bottom: 1.5rem;
            font-weight: 500;
            opacity: 0.95;
        }

        .auth-banner {
            display: flex;
            align-items: flex-start;
            gap: 0.5rem;
            padding: 0.75rem 1rem;
            margin-bottom: 1.25rem;
            font-size: 0.9rem;
            line-height: 1.45;
            border-radius: 10px;
            border: 1px solid transparent;
        }

        .auth-banner-error {
            background-color: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border-color: rgba(239, 68, 68, 0.2);
        }

        .auth-banner i {
            flex-shrink: 0;
            margin-top: 0.1rem;
        }

        .auth-validation-error {
            color: #f87171 !important;
            font-size: 0.8rem;
            margin-top: 0.35rem;
            display: block;
        }

        @@media (max-width: 768px) {
            body {
                padding: 20px 14px;
            }

            .auth-card {
                max-width: 100%;
                padding: 24px 18px;
                border-radius: 16px;
            }
        }

    </style>
</head>
<body>
    <div style="position: relative; z-index: 1;">
        <div class="auth-card">
            <div class="brand-logo">Bank<span class="text-blue">RED</span></div>
            <p class="auth-subtitle">Solicita tu acceso digital para validación del banco</p>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="auth-banner auth-banner-error" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@ViewBag.ErrorMessage</span>
                </div>
            }

            <form asp-action="Register" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nombre</label>
                        <div class="input-group-custom">
                            <i class="bi bi-person input-icon"></i>
                            <input asp-for="Nombre" class="form-control" placeholder="Juan" />
                        </div>
                        <span asp-validation-for="Nombre" class="auth-validation-error"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Apellido</label>
                        <div class="input-group-custom">
                            <i class="bi bi-person-add input-icon"></i>
                            <input asp-for="Apellido" class="form-control" placeholder="Pérez" />
                        </div>
                        <span asp-validation-for="Apellido" class="auth-validation-error"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Correo Electrónico</label>
                    <div class="input-group-custom">
                        <i class="bi bi-envelope input-icon"></i>
                        <input asp-for="Email" class="form-control" placeholder="ejemplo@banco.com" />
                    </div>
                    <span asp-validation-for="Email" class="auth-validation-error"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Cédula</label>
                        <div class="input-group-custom">
                            <i class="bi bi-person-vcard input-icon"></i>
                            <input asp-for="NationalId" class="form-control" placeholder="001-0000000-0" />
                        </div>
                        <span asp-validation-for="NationalId" class="auth-validation-error"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Teléfono</label>
                        <div class="input-group-custom">
                            <i class="bi bi-telephone input-icon"></i>
                            <input asp-for="Phone" class="form-control" placeholder="809-000-0000" />
                        </div>
                        <span asp-validation-for="Phone" class="auth-validation-error"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Contraseña</label>
                        <div class="input-group-custom">
                            <i class="bi bi-lock input-icon"></i>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="auth-validation-error"></span>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Confirmar Clave</label>
                        <div class="input-group-custom">
                            <i class="bi bi-shield-lock input-icon"></i>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="auth-validation-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn-primary-custom mb-4">
                    <i class="bi bi-person-plus-fill me-1"></i> Crear Cuenta
                </button>

                <div class="text-center" style="font-size: 0.95rem; color: #8b94a5;">
                    ¿Ya tienes una cuenta? <a asp-action="Login" asp-controller="Auth" class="auth-link">Inicia sesión</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
