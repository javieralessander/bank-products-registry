@model BankProductsRegistry.Frontend.Models.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BankRED - Crear Cuenta</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Fondo Bancario Moderno con Gradientes */
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            color: #ffffff;
            background: linear-gradient(135deg, #0f111a 0%, #151b2b 50%, #0f111a 100%);
            position: relative;
            overflow-x: hidden;
            padding: 40px 0;
        }

            /* Brillos sutiles */
            body::before {
                content: "";
                position: absolute;
                top: -10%;
                right: -10%;
                width: 60%;
                height: 60%;
                background: radial-gradient(circle, rgba(16, 185, 129, 0.08) 0%, transparent 60%);
                z-index: 0;
            }

            body::after {
                content: "";
                position: absolute;
                bottom: -10%;
                left: -10%;
                width: 60%;
                height: 60%;
                background: radial-gradient(circle, rgba(59, 130, 246, 0.12) 0%, transparent 60%);
                z-index: 0;
            }

        /* Tarjeta Glassmorphism (Un poco más ancha para el registro) */
        .auth-card {
            background: rgba(26, 29, 45, 0.65);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.6);
            padding: 40px;
            width: 100%;
            max-width: 500px;
            position: relative;
            z-index: 1;
        }

        .form-control {
            background-color: rgba(15, 17, 26, 0.7);
            border: 1px solid #2d3348;
            color: white;
            padding: 10px 14px;
            border-radius: 8px;
            transition: 0.3s;
        }

            .form-control:focus {
                background-color: rgba(21, 25, 40, 0.9);
                color: white;
                border-color: #3b82f6;
                box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25);
            }

            .form-control::placeholder {
                color: #6b7280;
            }

        .btn-primary {
            background: linear-gradient(90deg, #2563eb 0%, #3b82f6 100%);
            border: none;
            padding: 12px;
            font-weight: 600;
            border-radius: 8px;
            width: 100%;
            transition: 0.3s;
        }

            .btn-primary:hover {
                background: linear-gradient(90deg, #1d4ed8 0%, #2563eb 100%);
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
            }

        .brand-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-size: 1.5rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .brand-dot {
            width: 14px;
            height: 14px;
            background: linear-gradient(135deg, #60a5fa, #3b82f6);
            border-radius: 50%;
            box-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
        }

        .auth-link {
            color: #60a5fa;
            text-decoration: none;
            font-weight: 500;
            transition: 0.3s;
        }

            .auth-link:hover {
                color: #93c5fd;
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="brand-logo"><span class="brand-dot"></span> BankRED</div>
        <p class="text-center text-muted mb-4" style="font-size: 0.95rem;">Crea una nueva cuenta para acceder al sistema</p>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); font-size: 0.9rem;">
                @ViewBag.ErrorMessage
            </div>
        }

        <form asp-action="Register" method="post">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label text-muted" style="font-size: 0.85rem; font-weight: 500;">Nombre</label>
                    <input asp-for="Nombre" class="form-control" placeholder="Juan" />
                    <span asp-validation-for="Nombre" class="text-danger mt-1 d-block" style="font-size: 0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label text-muted" style="font-size: 0.85rem; font-weight: 500;">Apellido</label>
                    <input asp-for="Apellido" class="form-control" placeholder="Pérez" />
                    <span asp-validation-for="Apellido" class="text-danger mt-1 d-block" style="font-size: 0.8rem;"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted" style="font-size: 0.85rem; font-weight: 500;">Correo Electrónico</label>
                <input asp-for="Email" class="form-control" placeholder="ejemplo@banco.com" />
                <span asp-validation-for="Email" class="text-danger mt-1 d-block" style="font-size: 0.8rem;"></span>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted" style="font-size: 0.85rem; font-weight: 500;">Contraseña</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger mt-1 d-block" style="font-size: 0.8rem;"></span>
            </div>

            <div class="mb-4">
                <label class="form-label text-muted" style="font-size: 0.85rem; font-weight: 500;">Confirmar Contraseña</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="text-danger mt-1 d-block" style="font-size: 0.8rem;"></span>
            </div>

            <button type="submit" class="btn btn-primary mb-4">Crear Cuenta</button>

            <div class="text-center" style="font-size: 0.9rem; color: #8b94a5;">
                ¿Ya tienes una cuenta? <a asp-action="Login" asp-controller="Auth" class="auth-link">Inicia sesión</a>
            </div>
        </form>
    </div>
</body>
</html>