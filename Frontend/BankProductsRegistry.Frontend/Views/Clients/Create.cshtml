@model BankProductsRegistry.Frontend.Models.ClientViewModel
@using BankProductsRegistry.Frontend.Models
@{
    ViewData["Title"] = "Nuevo Cliente";
    var linkableUsers = ViewBag.LinkableUsers as IEnumerable<PendingClientUserViewModel> ?? new List<PendingClientUserViewModel>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    /* Transiciones globales para suavizar todo */
    * {
        transition: all 0.2s ease-in-out;
    }

    /* Estilos del Header */
    .page-header {
        margin-bottom: 28px;
    }

    .page-title {
        font-size: 1.6rem;
        font-weight: 700;
        margin-bottom: 4px;
        color: white;
        letter-spacing: -0.5px;
    }

    .page-subtitle {
        color: #8b94a5;
        font-size: 0.95rem;
    }

    /* LA TARJETA PRINCIPAL (Rediseño Estético) */
    .form-card-premium {
        background-color: #151928; /* Color Sidebar para profundidad */
        border-radius: 16px;
        border: 1px solid #2d3348;
        padding: 40px;
        max-width: 850px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3); /* Sombra suave */
        position: relative;
        overflow: hidden;
    }

        /* Detalle estético superior azul */
        .form-card-premium::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #3b82f6 0%, #1d4ed8 100%);
        }

    /* Títulos de Sección Internos */
    .section-title {
        font-size: 1rem;
        font-weight: 600;
        color: white;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-divider {
        border-top: 1px solid #2d3348;
        margin: 30px 0;
    }

    /* Estilos de Etiquetas (Labels) */
    .form-label-custom {
        color: #8b94a5;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* INPUTS ESTILIZADOS CON ICONOS (UX Mejorada) */
    .input-group-custom {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        left: 15px;
        color: #4b5563;
        font-size: 1.1rem;
        z-index: 10;
    }

    .form-control-custom {
        background-color: #0f111a; /* Fondo más oscuro para contraste */
        border: 1px solid #2d3348;
        color: white;
        padding: 12px 14px 12px 45px; /* Padding izquierdo extra para el icono */
        border-radius: 10px;
        font-size: 0.95rem;
    }

        .form-control-custom:focus {
            background-color: #0f111a;
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59,130,246,0.15); /* Brillo azul sutil */
            color: white;
            outline: none;
        }

        .form-control-custom::placeholder {
            color: #4b5563;
            font-size: 0.9rem;
        }

        /* Validaciones visuales */
        .form-control-custom:not(:placeholder-shown):valid {
            border-color: rgba(16, 185, 129, 0.4);
        }

    .btn-save-premium {
        background-color: #3b82f6; /* Respaldo para que Visual Studio no se queje */
        background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%);
        border: none;
        padding: 12px 30px;
        font-weight: 600;
        border-radius: 10px;
        color: white;
        font-size: 0.95rem;
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
        cursor: pointer;
    }

        .btn-save-premium:hover {
            background: linear-gradient(180deg, #60a5fa 0%, #3b82f6 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(37, 99, 235, 0.35);
            color: white;
        }

    .btn-cancel-custom {
        background-color: transparent;
        border: 1px solid #2d3348;
        padding: 12px 30px;
        font-weight: 600;
        border-radius: 10px;
        color: #8b94a5;
        text-decoration: none;
        font-size: 0.95rem;
        display: inline-flex;
        align-items: center;
    }

        .btn-cancel-custom:hover {
            background-color: #2d3348;
            color: white;
            border-color: #2d3348;
        }

    /* Alertas Estilizadas */
    .alert-custom {
        background-color: rgba(239, 68, 68, 0.08);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.15);
        border-radius: 10px;
        font-size: 0.9rem;
        padding: 15px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
</style>

<div class="page-header">
    <h1 class="page-title">Registrar Nuevo Cliente</h1>
    <div class="page-subtitle">Introduce la información requerida para el alta en el sistema Core.</div>
</div>

<div class="form-card-premium">
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-custom">
            <i class="bi bi-exclamation-octagon-fill fs-5"></i>
            <div><strong>Error de Validación:</strong> @ViewBag.ErrorMessage</div>
        </div>
    }

    <form asp-action="Create" method="post" autocomplete="off">

        <input type="hidden" asp-for="IsActive" value="true" />

        <div class="section-title">
            <i class="bi bi-person-badge-fill text-primary"></i> Datos Personales Básicos
        </div>

        <div class="row mb-4">
            <div class="col-md-6 mb-3 mb-md-0">
                <label class="form-label-custom">Nombres</label>
                <div class="input-group-custom">
                    <i class="bi bi-person input-icon"></i>
                    <input asp-for="FirstName" class="form-control-custom w-100" placeholder="Ej. Juan Antonio" required />
                </div>
            </div>
            <div class="col-md-6">
                <label class="form-label-custom">Apellidos</label>
                <div class="input-group-custom">
                    <i class="bi bi-person-add input-icon"></i>
                    <input asp-for="LastName" class="form-control-custom w-100" placeholder="Ej. Pérez Gómez" required />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12 mb-3">
                <label class="form-label-custom">Cédula de Identidad / Pasaporte</label>
                <div class="input-group-custom">
                    <i class="bi bi-card-text input-icon"></i>
                    <input asp-for="NationalId" class="form-control-custom w-100" placeholder="000-0000000-0" required />
                </div>
            </div>
        </div>

        <div class="section-divider"></div>

        <div class="section-title">
            <i class="bi bi-telephone-fill text-primary"></i> Información de Contacto
        </div>

        <div class="row mb-4">
            <div class="col-md-7 mb-3 mb-md-0">
                <label class="form-label-custom">Correo Electrónico Principal</label>
                <div class="input-group-custom">
                    <i class="bi bi-envelope-at input-icon"></i>
                    <input asp-for="Email" type="email" class="form-control-custom w-100" placeholder="usuario@dominio.com" required />
                </div>
            </div>
            <div class="col-md-5">
                <label class="form-label-custom">Teléfono Móvil</label>
                <div class="input-group-custom">
                    <i class="bi bi-phone input-icon"></i>
                    <input asp-for="Phone" class="form-control-custom w-100" placeholder="809-000-0000" required />
                </div>
            </div>
        </div>

        <div class="section-divider"></div>

        <div class="section-title">
            <i class="bi bi-link-45deg text-primary"></i> Cuenta de acceso (opcional)
        </div>
        <p class="small mb-3" style="color: #8b94a5;">
            Si eliges un usuario ya registrado, se le asignará el rol <strong>Cliente</strong> y quedará vinculado a este cliente al guardar.
        </p>
        <div class="row">
            <div class="col-md-12 mb-3">
                <label class="form-label-custom">Vincular usuario existente</label>
                <div class="input-group-custom">
                    <i class="bi bi-person-check input-icon"></i>
                    <select asp-for="LinkUserId" class="form-control-custom w-100" id="LinkUserId" style="padding-left: 45px;">
                        <option value="">— Sin vincular —</option>
                        @foreach (var u in linkableUsers)
                        {
                            <option value="@u.Id"
                                    data-full-name="@u.FullName"
                                    data-first-name="@u.FirstName"
                                    data-last-name="@u.LastName"
                                    data-email="@u.Email"
                                    data-national-id="@u.NationalId"
                                    data-phone="@u.Phone">
                                @u.FullName (@u.UserName)
                            </option>
                        }
                    </select>
                </div>
                <div class="mt-2" style="color: #8b94a5; font-size: 0.82rem;">
                    El sistema completará los datos del formulario con la información del usuario registrado para agilizar el alta.
                </div>
            </div>
        </div>

        <div class="d-flex gap-3 justify-content-end mt-5 pt-3 border-top" style="border-color: #2d3348;">
            <a asp-action="Index" class="btn-cancel-custom">
                <i class="bi bi-arrow-left me-1"></i> Cancelar
            </a>
            <button type="submit" class="btn-save-premium">
                <i class="bi bi-cloud-check-fill me-2"></i> Guardar Cliente
            </button>
        </div>
    </form>
</div>

<script>
    (function () {
        const userSelect = document.getElementById("LinkUserId");
        const firstNameInput = document.getElementById("FirstName");
        const lastNameInput = document.getElementById("LastName");
        const emailInput = document.getElementById("Email");
        const nationalIdInput = document.getElementById("NationalId");
        const phoneInput = document.getElementById("Phone");

        function splitFullName(fullName) {
            const value = (fullName || "").trim();
            if (!value) {
                return { firstName: "", lastName: "" };
            }

            const parts = value.split(/\s+/);
            if (parts.length === 1) {
                return { firstName: parts[0], lastName: "" };
            }

            return {
                firstName: parts[0],
                lastName: parts.slice(1).join(" ")
            };
        }

        function syncFromSelectedUser() {
            if (!userSelect) {
                return;
            }

            const selectedOption = userSelect.options[userSelect.selectedIndex];
            if (!selectedOption || !selectedOption.value) {
                return;
            }

            const derivedName = splitFullName(selectedOption.dataset.fullName);
            const firstName = selectedOption.dataset.firstName || derivedName.firstName;
            const lastName = selectedOption.dataset.lastName || derivedName.lastName;

            if (firstNameInput) {
                firstNameInput.value = firstName || "";
            }

            if (lastNameInput) {
                lastNameInput.value = lastName || "";
            }

            if (emailInput) {
                emailInput.value = selectedOption.dataset.email || "";
            }

            if (nationalIdInput) {
                nationalIdInput.value = selectedOption.dataset.nationalId || "";
            }

            if (phoneInput) {
                phoneInput.value = selectedOption.dataset.phone || "";
            }
        }

        if (userSelect) {
            userSelect.addEventListener("change", syncFromSelectedUser);
            if (userSelect.value) {
                syncFromSelectedUser();
            }
        }
    })();
</script>
